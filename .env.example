# ── Database ──────────────────────────────────────────────────────────────────
# Full connection string (used by the backend and data-load scripts)
DATABASE_URL=postgresql://f1user:f1password@localhost:5432/f1_intelligence_hub

# Individual fields (used by Docker Compose service env-vars)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=f1_intelligence_hub
DB_USER=f1user
DB_PASSWORD=f1password

# ── FastF1 cache ──────────────────────────────────────────────────────────────
# Local directory where FastF1 stores downloaded session files
FASTF1_CACHE_DIR=./fastf1_cache

# ── Backend ───────────────────────────────────────────────────────────────────
# Comma-separated origins the backend allows (add your LAN IP if needed)
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL the browser uses to reach the API
# Keep this as localhost:8000 for local development
NEXT_PUBLIC_API_URL=http://localhost:8000
